{
  "name": "wysiwyg4all",
  "version": "1.1.2",
  "description": "Free opensource minimal WYSIWYG editor for web developers",
  "main": "dist/wysiwyg4all.module.cjs",
  "module": "dist/wysiwyg4all.module.js",
  "types": "dist/wysiwyg4all.d.ts",
  "browser": "dist/wysiwyg4all.js",
  "unpkg": "dist/wysiwyg4all.js",
  "jsdelivr": "dist/wysiwyg4all.js",
  "exports": {
    ".": {
      "types": "./dist/wysiwyg4all.d.ts",
      "browser": "./dist/wysiwyg4all.js",
      "require": "./dist/wysiwyg4all.module.cjs",
      "import": "./dist/wysiwyg4all.module.js",
      "default": "./dist/wysiwyg4all.module.js"
    },
    "./css": "./dist/wysiwyg4all.css"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/broadwayinc/wysiwyg4all"
  },
  "scripts": {
    "dev": "npx bns port=5173",
    "build": "npm run build:js && npm run build:css",
    "build:js": "tsup",
    "build:css": "npx lessc wysiwyg4all.less dist/wysiwyg4all.css"
  },
  "keywords": [
    "wysiwyg",
    "opensource",
    "editor",
    "html",
    "web",
    "javascript",
    "free"
  ],
  "author": "Baksa Gimm",
  "license": "MIT",
  "devDependencies": {
    "less": "^4.6.4",
    "tsup": "^8.3.5"
  },
  "dependencies": {
    "basic-node-server": "^1.1.0"
  }
}
